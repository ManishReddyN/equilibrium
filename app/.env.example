# Local dev: `supabase start` prints these (SUPABASE_URL -> API_URL, SUPABASE_ANON_KEY -> ANON_KEY).
# Android emulator note: use http://10.0.2.2:54321, not http://127.0.0.1:54321 -- 127.0.0.1 from
# inside the emulator means the emulator itself, not your host machine. A real device over
# adb/USB needs `adb reverse` or your host's LAN IP instead; iOS Simulator can use 127.0.0.1
# directly since it shares the host's network namespace.
SUPABASE_URL=
SUPABASE_ANON_KEY=
